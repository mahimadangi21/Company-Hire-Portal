# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (can opt-in for commiting if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Verify .gitignore contains:
.env*.local
/public/uploads

# Debug / utility scripts (contain DB secrets - never commit)
check_*.js
fix_*.js
run_migration.js
test_*.js
download_sample_video.js
backfill*.js
fix_*.js
seed*.js
migrate*.js
debug*.js
